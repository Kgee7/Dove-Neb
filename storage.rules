
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check ownership via metadata
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Profile pictures: users can only upload to their own folder, if they own the content.
    match /profilePictures/{userId}/{allPaths=**} {
      allow read;
      allow write: if isOwner(userId) && request.resource.metadata.owner == request.auth.uid;
    }

    // Resumes: users can only upload to their own folder, if they own the content.
    match /resumes/{userId}/{allPaths=**} {
      allow read;
      allow write: if isOwner(userId) && request.resource.metadata.owner == request.auth.uid;
    }

    // Room images: users can only upload to their own folder, if they own the content.
    match /rooms/{userId}/{allPaths=**} {
      allow read;
      allow write: if isOwner(userId) && request.resource.metadata.owner == request.auth.uid;
    }
  }
}
