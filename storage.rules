rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User profile pictures: only the user can upload, anyone can read.
    match /users/{userId}/profilePicture {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User resumes: only the user can upload, anyone can read.
    match /users/{userId}/resume/{fileName} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Room images: anyone authenticated can upload, anyone can read.
    // The application logic ensures that only room owners can upload to their own rooms.
    match /rooms/{roomId}/{imageId} {
      allow read;
      allow write: if request.auth != null;
    }
  }
}
