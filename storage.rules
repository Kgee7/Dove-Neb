rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow users to read and write to their own profile pictures directory
    match /profilePictures/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users to read and write to their own resumes directory
    match /resumes/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to read and write to the rooms directory
    // This is more permissive for now to ensure functionality.
    // In a production app, you might restrict this further.
    match /rooms/{userId}/{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow public read on room images
    match /rooms/{userId}/{imageId} {
      allow get;
    }
  }
}
