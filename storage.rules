rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Users can only write to their own profile picture directory.
    // Anyone can read profile pictures.
    match /profilePictures/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can only read and write their own resumes.
    match /resumes/{userId}/{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can only write to their own rooms directory.
    // Anyone can read room images.
    match /rooms/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
