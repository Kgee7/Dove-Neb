rules_version = '2';

// By default, deny all reads and writes
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the file
    // This relies on the client sending a 'owner' key in the file metadata
    function isOwner(userId) {
      return request.resource.metadata.owner == userId;
    }

    // Profile pictures can be read by anyone, but only written by the owner
    match /profilePictures/{userId}/{allPaths=**} {
      allow read;
      allow write: if isAuthenticated() && isOwner(userId);
    }

    // Resumes can be read by anyone, but only written by the owner
    // Note: In a real-world app, you might restrict read access for resumes.
    match /resumes/{userId}/{allPaths=**} {
      allow read;
      allow write: if isAuthenticated() && isOwner(userId);
    }

    // Room images can be read by anyone, but only written by the room owner
    match /rooms/{userId}/{allPaths=**} {
      allow read;
      allow write: if isAuthenticated() && isOwner(userId);
    }
  }
}
