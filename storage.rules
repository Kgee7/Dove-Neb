rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile pictures: Users can write to their own folder, anyone can read.
    match /profilePictures/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Resumes: Users can write to their own folder, anyone can read.
    // Consider making read access more restrictive if resumes are private.
    match /resumes/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Room images: Users can write to their own room image folders, anyone can read.
    match /rooms/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
