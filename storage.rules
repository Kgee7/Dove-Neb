
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check ownership via metadata
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Profile pictures: users can only upload to their own folder.
    match /profilePictures/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId);
    }

    // Resumes: users can only upload to their own folder.
    match /resumes/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId);
    }

    // Room images: users can only upload to their own folder.
    match /rooms/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId);
    }
  }
}
