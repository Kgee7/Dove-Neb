
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow public read access to all files.
    // This is necessary for the app to display images.
    match /{allPaths=**} {
      allow read;
    }

    // --- Profile Pictures ---
    // Allow a user to upload/update/delete their own profile picture.
    // The client SDK includes the user's UID in the file metadata.
    // We check that the metadata's 'owner' field matches the authenticated user's UID.
    match /profilePictures/{userId}/{fileName} {
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.metadata.owner == request.auth.uid;
    }

    // --- Resumes ---
    // Allow a user to upload/update/delete their own resume.
    match /resumes/{userId}/{fileName} {
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.metadata.owner == request.auth.uid;
    }

    // --- Room Images ---
    // Allow a user to upload/update/delete images for their own rooms.
    match /rooms/{userId}/{fileId} {
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.metadata.owner == request.auth.uid;
    }
  }
}

    