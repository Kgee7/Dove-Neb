
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the platform, either a renter or an owner.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "userType": {
          "type": "string",
          "description": "The type of user (e.g., renter, owner)."
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "photoURL": {
          "type": "string",
          "description": "URL of the user's profile picture."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userType",
        "firstName",
        "lastName",
        "email"
      ]
    },
    "Room": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Room",
      "type": "object",
      "description": "Represents a room listing on the platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Room entity."
        },
        "ownerId": {
          "type": "string",
          "description": "Reference to the User (Owner) who listed the room."
        },
        "ownerName": {
          "type": "string",
          "description": "The name of the owner who listed the room."
        },
        "title": {
          "type": "string",
          "description": "The title of the room listing."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the room."
        },
        "location": {
          "type": "string",
          "description": "The city and country where the room is located."
        },
        "price": {
          "type": "number",
          "description": "The price per night for the room."
        },
        "currency": {
          "type": "string",
          "description": "The currency of the price (e.g., USD, EUR)."
        },
        "currencySymbol": {
            "type": "string",
            "description": "The symbol for the currency (e.g., $, €, £)."
        },
        "images": {
            "type": "array",
            "description": "A list of URLs for the room images.",
            "items": {
                "type": "string",
                "format": "uri"
            }
        },
         "amenities": {
          "type": "array",
          "description": "A list of amenities offered with the room.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "ownerId",
        "ownerName",
        "title",
        "description",
        "location",
        "price",
        "currency",
        "currencySymbol",
        "images"
      ]
    },
     "Booking": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Booking",
      "type": "object",
      "description": "Represents a booking made by a user for a room.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Booking entity."
        },
        "roomId": {
          "type": "string",
          "description": "Reference to the Room being booked."
        },
        "renterId": {
          "type": "string",
          "description": "Reference to the User (Renter) who made the booking."
        },
        "checkInDate": {
          "type": "string",
          "format": "date"
        },
        "checkOutDate": {
          "type": "string",
          "format": "date"
        },
        "totalPrice": {
          "type": "number"
        },
        "status": {
            "type": "string",
            "enum": ["pending", "confirmed", "cancelled"]
        }
      },
      "required": [
        "id",
        "roomId",
        "renterId",
        "checkInDate",
        "checkOutDate",
        "totalPrice",
        "status"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/rooms/{roomId}",
        "definition": {
          "entityName": "Room",
          "schema": {
            "$ref": "#/backend/entities/Room"
          },
          "description": "Top level Rooms collection for searching and listing all rooms.",
          "publicRead": true
        }
      },
       {
        "path": "/users/{userId}/bookings/{bookingId}",
        "definition": {
          "entityName": "Booking",
          "schema": {
            "$ref": "#/backend/entities/Booking"
          },
          "description": "Stores bookings made by users."
        }
      }
    ]
  }
}
