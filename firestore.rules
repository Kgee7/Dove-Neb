/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure authorization while permitting flexible data shapes
 * to enable rapid prototyping. It uses a strict ownership model for user-specific data
 * and allows public read access to certain top-level collections with owner-only writes.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only to the owning user.
 * - /jobs/{jobId}: Top-level collection for job listings, publicly readable, writeable only by the job poster.
 * - /users/{userId}/applications/{applicationId}: Stores job applications, accessible only to the owning user.
 * - /rooms/{roomId}: Top-level collection for room listings, publicly readable, writeable only by the room poster.
 * - /users/{userId}/bookings/{bookingId}: Stores room bookings, accessible only to the owning user.
 *
 * Key Security Decisions:
 * - User listing is disallowed for privacy.
 * - Public read access is granted to the /jobs and /rooms collections to facilitate discovery.
 * - Write access to /jobs and /rooms is restricted to the owner (creator) of the listing.
 *
 * Denormalization for Authorization:
 *  - The `jobs` collection requires that the `employerId` field matches the authenticated user's UID when creating a job.
 *  - The `rooms` collection requires that the `ownerId` field matches the authenticated user's UID when creating a room.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create, update, delete) if the user is the owner of the document (userId matches request.auth.uid).
     * @allow (get, list) if the user is the owner of the document (userId matches request.auth.uid).
     * @deny (create) if the user is not signed in.
     * @deny (update) if the user is not the owner of the document.
     * @deny (delete) if the user is not the owner of the document.
     * @principle Enforces document ownership for writes and reads, ensuring users can only access their own profile data.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to job listing documents.
     * @path /jobs/{jobId}
     * @allow (get, list) to anyone.
     * @allow (create) if the user is signed in and the employerId matches the request.auth.uid.
     * @allow (update, delete) if the user is the owner of the document (employerId matches request.auth.uid).
     * @deny (create) if the user is not signed in.
     * @deny (update) if the user is not the owner of the document.
     * @deny (delete) if the user is not the owner of the document.
     * @principle Public read access with owner-only writes, allowing anyone to view job listings, but only the creator can modify them.
     */
    match /jobs/{jobId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(employerId) {
        return request.auth.uid == employerId;
      }

      function isExistingOwner(employerId) {
        return isOwner(employerId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && isOwner(request.resource.data.employerId);
      allow update: if isExistingOwner(resource.data.employerId);
      allow delete: if isExistingOwner(resource.data.employerId);
    }

    /**
     * @description Controls access to job application documents under a user's profile.
     * @path /users/{userId}/applications/{applicationId}
     * @allow (create, update, delete) if the user is the owner of the parent user document (userId matches request.auth.uid).
     * @allow (get, list) if the user is the owner of the parent user document (userId matches request.auth.uid).
     * @deny (create) if the user is not signed in.
     * @deny (update) if the user is not the owner of the parent user document.
     * @deny (delete) if the user is not the owner of the parent user document.
     * @principle Enforces document ownership for writes and reads, ensuring users can only access their own job applications.
     */
    match /users/{userId}/applications/{applicationId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to room listing documents.
     * @path /rooms/{roomId}
     * @allow (get, list) to anyone.
     * @allow (create) if the user is signed in and the ownerId matches the request.auth.uid.
     * @allow (update, delete) if the user is the owner of the document (ownerId matches request.auth.uid).
     * @deny (create) if the user is not signed in.
     * @deny (update) if the user is not the owner of the document.
     * @deny (delete) if the user is not the owner of the document.
     * @principle Public read access with owner-only writes, allowing anyone to view room listings, but only the creator can modify them.
     */
    match /rooms/{roomId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(ownerId) {
        return request.auth.uid == ownerId;
      }

      function isExistingOwner(ownerId) {
        return isOwner(ownerId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && isOwner(request.resource.data.ownerId);
      allow update: if isExistingOwner(resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Controls access to booking documents under a user's profile.
     * @path /users/{userId}/bookings/{bookingId}
     * @allow (create, update, delete) if the user is the owner of the parent user document (userId matches request.auth.uid).
     * @allow (get, list) if the user is the owner of the parent user document (userId matches request.auth.uid).
     * @deny (create) if the user is not signed in.
     * @deny (update) if the user is not the owner of the parent user document.
     * @deny (delete) if the user is not the owner of the parent user document.
     * @principle Enforces document ownership for writes and reads, ensuring users can only access their own bookings.
     */
    match /users/{userId}/bookings/{bookingId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}