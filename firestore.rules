/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes strict user-ownership and public-read access where appropriate,
 * while maintaining flexibility for rapid data model iteration.
 * All write operations are guarded by authorization checks.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only by the owning user.
 * - /jobs/{jobId}: Publicly readable job listings, writable only by the job poster.
 * - /users/{userId}/applications/{applicationId}: Job applications submitted by a user, accessible only by the user.
 * - /rooms/{roomId}: Publicly readable room listings, writable only by the room owner.
 * - /users/{userId}/bookings/{bookingId}: Room bookings made by a user, accessible only by the user.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Public read access is granted to the `jobs` and `rooms` collections.
 * - Write operations require authentication.
 *
 * Denormalization for Authorization:
 * - The rules assume that documents in the `jobs` and `rooms` collections contain fields like `employerId` and `ownerId` respectively,
 *   which are used to enforce ownership during write operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (get) Authenticated user can read their own profile.
     * @allow (create) Authenticated user can create their own profile.
     * @allow (update) Authenticated user can update their own profile.
     * @allow (delete) Authenticated user can delete their own profile.
     * @deny (get) Authenticated user cannot read other user profiles.
     * @deny (create) Authenticated user cannot create profiles for other users.
     * @deny (update) Authenticated user cannot update other user profiles.
     * @deny (delete) Authenticated user cannot delete other user profiles.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to job listings.
     * @path /jobs/{jobId}
     * @allow (get, list) Anyone can read job listings.
     * @allow (create) Authenticated user can create a job listing with their ID as the employerId.
     * @allow (update) Authenticated user can update their job listing.
     * @allow (delete) Authenticated user can delete their job listing.
     * @deny (create) Unauthenticated user cannot create a job listing.
     * @deny (update) Authenticated user cannot update other users' job listings.
     * @deny (delete) Authenticated user cannot delete other users' job listings.
     * @principle Allows public reads and restricts writes to the job poster.
     */
    match /jobs/{jobId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(employerId) {
        return isSignedIn() && request.auth.uid == employerId;
      }

      function isExistingOwner(employerId) {
        return isOwner(employerId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.employerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.employerId);
      allow delete: if isExistingOwner(resource.data.employerId);
    }

    /**
     * @description Controls access to job applications.
     * @path /users/{userId}/applications/{applicationId}
     * @allow (get) Authenticated user can read their own job applications.
     * @allow (create) Authenticated user can create a job application.
     * @allow (update) Authenticated user can update their job application.
     * @allow (delete) Authenticated user can delete their job application.
     * @deny (get) Authenticated user cannot read other users' job applications.
     * @deny (create) Authenticated user cannot create job applications for other users.
     * @deny (update) Authenticated user cannot update other users' job applications.
     * @deny (delete) Authenticated user cannot delete other users' job applications.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/applications/{applicationId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.seekerId == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.seekerId == resource.data.seekerId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to room listings.
     * @path /rooms/{roomId}
     * @allow (get, list) Anyone can read room listings.
     * @allow (create) Authenticated user can create a room listing with their ID as the ownerId.
     * @allow (update) Authenticated user can update their room listing.
     * @allow (delete) Authenticated user can delete their room listing.
     * @deny (create) Unauthenticated user cannot create a room listing.
     * @deny (update) Authenticated user cannot update other users' room listings.
     * @deny (delete) Authenticated user cannot delete other users' room listings.
     */
    match /rooms/{roomId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(ownerId) {
        return isSignedIn() && request.auth.uid == ownerId;
      }

      function isExistingOwner(ownerId) {
        return isOwner(ownerId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Controls access to room bookings.
     * @path /users/{userId}/bookings/{bookingId}
     * @allow (get) Authenticated user can read their own room bookings.
     * @allow (create) Authenticated user can create a room booking.
     * @allow (update) Authenticated user can update their room booking.
     * @allow (delete) Authenticated user can delete their room booking.
     * @deny (get) Authenticated user cannot read other users' room bookings.
     * @deny (create) Authenticated user cannot create room bookings for other users.
     * @deny (update) Authenticated user cannot update other users' room bookings.
     * @deny (delete) Authenticated user cannot delete other users' room bookings.
     */
    match /users/{userId}/bookings/{bookingId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.renterId == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.renterId == resource.data.renterId;
      allow delete: if isExistingOwner(userId);
    }
  }
}