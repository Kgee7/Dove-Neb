
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // USER PROFILES
    // Users can read and write to their own profile.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // USER SUBCOLLECTIONS
    // A user can manage their own applications and bookings.
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if isOwner(userId);
    }

    // PUBLIC JOB LISTINGS
    // Anyone can read job listings.
    // Only authenticated employers can create jobs.
    // Only the employer who created the job can update or delete it.
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isOwner(resource.data.employerId);
    }

    // PUBLIC ROOM LISTINGS
    // Anyone can read room listings.
    // Only authenticated users can create rooms.
    // Only the user who created the room can update or delete it.
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isOwner(resource.data.ownerId);
    }
  }
}
