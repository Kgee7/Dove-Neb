/**
 * @fileoverview Firestore Security Rules for the Room Booking Application.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure data access based on user roles and ownership.
 * Public read access is granted to the `rooms` collection, but writes are restricted to owners.
 * Users have full access to their own data tree under `/users/{userId}`.
 *
 * Data Structure:
 * - `/users/{userId}`: Stores user profiles. Access is restricted to the user themselves.
 * - `/rooms/{roomId}`: Stores room listings. Publicly readable, but only the owner can modify.
 * - `/users/{userId}/bookings/{bookingId}`: Stores booking information for a specific user. Accessible only by the user.
 *
 * Key Security Decisions:
 * - Users can only manage their own profiles and bookings.
 * - Listing of users is disallowed for privacy.
 * - Public read access is granted to the `rooms` collection.
 *
 * Denormalization for Authorization:
 * - The `Room` entity includes an `ownerId` field to simplify ownership checks.
 *
 * Structural Segregation:
 * - Private user data (bookings) is stored in a subcollection under the user's document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the current user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the current user is the owner of the resource.
     * @param {string} userId - The user ID to compare against the request's auth UID.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the current user is the existing owner of the resource.
     * @param {string} userId - The user ID to compare against the request's auth UID and the resource's owner ID.
     * @return {bool} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Security rules for user profiles.
     * @path /users/{userId}
     * @allow (create) - If the user is creating their own profile (IDs match).
     * @allow (get, update, delete) - If the user is the owner of the profile.
     * @deny (create) - If the user ID in the request does not match the authenticated user ID.
     * @deny (update, delete) - If the user is not the owner of the profile or the profile doesn't exist.
     * @deny (list) - Listing users is not allowed.
     * @principle Enforces user ownership for profile data.
     */
    match /users/{userId} {
      // Only allow a user to create their own profile.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      // Only allow the user to read, update, and delete their own profile.
      allow get, update, delete: if isExistingOwner(userId);
      // No listing of users.
      allow list: if false;
    }

    /**
     * @description Security rules for room listings.
     * @path /rooms/{roomId}
     * @allow (get, list) - Public read access for all rooms.
     * @allow (create) - Only if the ownerId matches the authenticated user and other required fields are present.
     * @allow (update, delete) - Only the owner can update or delete the room, and the room must exist.
     * @deny (create) - If the ownerId does not match the authenticated user or required fields are missing.
     * @deny (update, delete) - If the user is not the owner of the room or the room doesn't exist.
     * @principle Allows public reading of rooms but restricts modifications to the owner.
     */
    match /rooms/{roomId} {
      // Allow public read access to room listings.
      allow get, list: if true;

      // Only allow creating a room if the ownerId matches the authenticated user.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Only the owner can update or delete the room, and the room must exist.
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Security rules for bookings under a user's profile.
     * @path /users/{userId}/bookings/{bookingId}
     * @allow (create, get, update, delete, list) - Only if the user is the owner.
     * @deny (create, get, update, delete, list) - If the user is not the owner.
     * @principle Restricts access to bookings to the owner.
     */
    match /users/{userId}/bookings/{bookingId} {
      // Only allow the user to create, read, update, delete, and list their own bookings.
      allow create, get, update, delete, list: if isOwner(userId);
    }
  }
}