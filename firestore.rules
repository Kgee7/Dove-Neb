/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure authorization while relaxing data validation to accelerate prototyping.
 * It focuses on who can access what, not necessarily the precise shape of the data.
 *
 * Data Structure:
 * - Users: /users/{userId} - Stores individual user profiles.
 * - Jobs: /jobs/{jobId} - Stores job listings. Publicly readable, but owner-only writes.
 * - Job Applications: /users/{userId}/applications/{applicationId} - Stores job applications submitted by a user.
 * - Rooms: /rooms/{roomId} - Stores room listings. Publicly readable, but owner-only writes.
 * - Bookings: /users/{userId}/bookings/{bookingId} - Stores bookings made by a user.
 *
 * Key Security Decisions:
 * - Users can only read/write their own data under /users/{userId}.
 * - Job listings and rooms are publicly readable but writable only by the owner.
 * - Listing of users is disallowed.
 *
 * Denormalization for Authorization:
 * - Jobs and Rooms will rely on an `employerId` and `ownerId` field, respectively, to enforce owner-only writes.
 *   These fields must match `request.auth.uid` on creation and remain immutable on updates.
 *
 * Structural Segregation:
 * - Draft vs. published content is not explicitly handled, but the public read with owner-only write pattern on
 *   top-level collections supports this implicitly (e.g., a user can create a job listing and publish it when ready).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @principle Verified Identity: All authorization decisions must rely on request.auth.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId The user ID to compare against the request's auth UID.
     * @principle Ownership: Restricts access to resources based on user ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the resource.
     *              Combines the ownership check with the existence check.
     * @param {string} userId The user ID to compare against the request's auth UID.
     * @principle Ownership: Restricts access to resources based on user ownership.
     * @principle Robustness: Verifies the document exists before allowing updates or deletes.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rule for the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (create) - Authenticated user with matching UID can create their own user document.
     * @allow (get, update, delete) - Authenticated user with matching UID can read/write their own user document.
     * @deny (create) - Unauthenticated user cannot create user documents.
     * @deny (get, update, delete) - Another authenticated user cannot read/write a different user's document.
     * @principle Ownership: Enforces strict user-ownership for all operations.
     * @principle Self-Creation: Allows a user to create their own document with matching UID.
     */
    match /users/{userId} {
      allow get, update, delete: if isExistingOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow list: if false;
    }

    /**
     * @description Rule for the /jobs/{jobId} collection.
     * @path /jobs/{jobId}
     * @allow (get, list) - Any user (signed in or not) can read job listings.
     * @allow (create) - Authenticated user can create a job listing if they are the employer.
     * @allow (update, delete) - Only the employer who created the job can modify or delete it.
     * @deny (create) - Unauthenticated users cannot create job listings.
     * @deny (update, delete) - Other authenticated users cannot modify or delete job listings.
     * @principle Public Read with Owner-Only Writes: Allows public access for reading, but restricts writes to the owner.
     */
    match /jobs/{jobId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.employerId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.employerId);
    }

    /**
     * @description Rule for the /users/{userId}/applications/{applicationId} collection.
     * @path /users/{userId}/applications/{applicationId}
     * @allow (get, list, create, update, delete) - Authenticated user with matching UID can manage their own job applications.
     * @deny (create) - Unauthenticated user cannot create job application documents.
     * @deny (get, update, delete) - Another authenticated user cannot manage a different user's job application documents.
     * @principle Ownership: Enforces strict user-ownership for all operations.
     */
    match /users/{userId}/applications/{applicationId} {
      allow get, list, update, delete: if isExistingOwner(userId);
      allow create: if isOwner(userId);
    }

     /**
      * @description Rule for the /rooms/{roomId} collection.
      * @path /rooms/{roomId}
      * @allow (get, list) - Any user can read room listings.
      * @allow (create) - Authenticated user can create a room listing if they are the owner.
      * @allow (update, delete) - Only the owner who created the room can modify or delete it.
      * @deny (create) - Unauthenticated users cannot create room listings.
      * @deny (update, delete) - Other authenticated users cannot modify or delete room listings.
      * @principle Public Read with Owner-Only Writes: Allows public access for reading, but restricts writes to the owner.
      */
    match /rooms/{roomId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Rule for the /users/{userId}/bookings/{bookingId} collection.
     * @path /users/{userId}/bookings/{bookingId}
     * @allow (get, list, create, update, delete) - Authenticated user with matching UID can manage their own bookings.
     * @deny (create) - Unauthenticated user cannot create booking documents.
     * @deny (get, update, delete) - Another authenticated user cannot manage a different user's booking documents.
     * @principle Ownership: Enforces strict user-ownership for all operations.
     */
    match /users/{userId}/bookings/{bookingId} {
      allow get, list, update, delete: if isExistingOwner(userId);
      allow create: if isOwner(userId);
    }
  }
}