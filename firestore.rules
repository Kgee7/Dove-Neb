
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // USER PROFILES
    // Users can read and write to their own profile.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // USER SUBCOLLECTIONS
    // A user can manage their own bookings and create their own applications.
    match /users/{userId}/bookings/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/applications/{applicationId} {
      // A user can read, create, and delete their own applications.
      allow read, create, delete: if isOwner(userId);
    }

    // PUBLIC JOB LISTINGS
    // Anyone can read job listings.
    // Only authenticated employers can create jobs.
    // Only the employer who created the job can update or delete it.
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.employerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.employerId);
    }
    
    // JOB APPLICANTS SUBCOLLECTION
    match /jobs/{jobId}/applicants/{applicantId} {
        // The job owner can list all applicants.
        allow list: if get(/databases/$(database)/documents/jobs/$(jobId)).data.employerId == request.auth.uid;
        
        // The job owner can read individual applicant docs.
        // A seeker can read their OWN application record to check the status.
        allow get: if get(/databases/$(database)/documents/jobs/$(jobId)).data.employerId == request.auth.uid ||
                       (request.auth != null && resource.data.seekerId == request.auth.uid);
        
        // An authenticated user (seeker) can create an application for a job.
        allow create: if request.auth != null && request.resource.data.seekerId == request.auth.uid;
        
        // Only the employer who owns the job can update or delete applications.
        allow update, delete: if get(/databases/$(database)/documents/jobs/$(jobId)).data.employerId == request.auth.uid;
    }

    // PUBLIC ROOM LISTINGS
    // Anyone can read room listings.
    // Only authenticated users can create rooms.
    // Only the user who created the room can update or delete it.
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.ownerId);
    }
  }
}

    