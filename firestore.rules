/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure authorization based on user identity and
 * resource ownership, while relaxing data validation to enable rapid
 * prototyping. Data types and schema validation are mostly skipped. All write
 * operations are protected by authorization checks.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles.
 * - /jobs/{jobId}: Stores job listings.
 * - /users/{userId}/applications/{applicationId}: Stores job applications.
 * - /rooms/{roomId}: Stores room listings.
 * - /users/{userId}/bookings/{bookingId}: Stores room bookings.
 *
 * Key Security Decisions:
 * - User data is strictly controlled by the owning user.
 * - Job and room listings are publicly readable but writable only by owners.
 * - Data consistency between path segments and document fields is enforced on create and update.
 *
 * Denormalization for Authorization:
 *  - The rules depend on the document `id` fields matching the Firestore document IDs in paths like `/users/{userId}`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to manage their own profiles.
     * @path /users/{userId}
     * @allow (create) User with matching ID can create their profile.
     * @allow (update) User with matching ID can update their profile.
     * @allow (delete) User with matching ID can delete their profile.
     * @allow (get) User with matching ID can get their profile.
     * @allow (list) Listing users is disallowed.
     * @deny (create) User tries to create a profile with a different ID.
     * @deny (update) User tries to update someone else's profile.
     * @deny (delete) User tries to delete someone else's profile.
     * @principle Enforces document ownership for writes, restricts listing.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to job listings, with owner-only writes.
     * @path /jobs/{jobId}
     * @allow (get, list) Anyone can read job listings.
     * @allow (create) User can create a job listing with their ID as employerId.
     * @allow (update) Owner can update a job listing they own.
     * @allow (delete) Owner can delete a job listing they own.
     * @deny (create) User tries to create a job listing with incorrect employerId.
     * @deny (update) User tries to update a job listing they don't own.
     * @deny (delete) User tries to delete a job listing they don't own.
     * @principle Public read, owner-only writes, ownership enforced via employerId.
     */
    match /jobs/{jobId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(employerId) {
        return isSignedIn() && request.auth.uid == employerId;
      }
      function isExistingOwner(employerId) {
        return isOwner(employerId) && resource != null;
      }

      allow get, list: if true;

      allow create: if isSignedIn() && request.resource.data.employerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.employerId);
      allow delete: if isExistingOwner(resource.data.employerId);
    }

    /**
     * @description Allows users to manage their own job applications.
     * @path /users/{userId}/applications/{applicationId}
     * @allow (create) User with matching ID can create a job application.
     * @allow (update) User with matching ID can update their job application.
     * @allow (delete) User with matching ID can delete their job application.
     * @allow (get) User with matching ID can get their job application.
     * @allow (list) User with matching ID can list their job applications.
     * @deny (create) User tries to create a job application for a different user.
     * @deny (update) User tries to update someone else's job application.
     * @deny (delete) User tries to delete someone else's job application.
     * @principle Enforces document ownership, restricts access to a user's own data.
     */
    match /users/{userId}/applications/{applicationId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.seekerId == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.seekerId == resource.data.seekerId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to room listings, with owner-only writes.
     * @path /rooms/{roomId}
     * @allow (get, list) Anyone can read room listings.
     * @allow (create) User can create a room listing with their ID as ownerId.
     * @allow (update) Owner can update a room listing they own.
     * @allow (delete) Owner can delete a room listing they own.
     * @deny (create) User tries to create a room listing with incorrect ownerId.
     * @deny (update) User tries to update a room listing they don't own.
     * @deny (delete) User tries to delete a room listing they don't own.
     * @principle Public read, owner-only writes, ownership enforced via ownerId.
     */
    match /rooms/{roomId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(ownerId) {
        return isSignedIn() && request.auth.uid == ownerId;
      }
      function isExistingOwner(ownerId) {
        return isOwner(ownerId) && resource != null;
      }

      allow get, list: if true;

      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Allows users to manage their own room bookings.
     * @path /users/{userId}/bookings/{bookingId}
     * @allow (create) User with matching ID can create a room booking.
     * @allow (update) User with matching ID can update their room booking.
     * @allow (delete) User with matching ID can delete their room booking.
     * @allow (get) User with matching ID can get their room booking.
     * @allow (list) User with matching ID can list their room bookings.
     * @deny (create) User tries to create a room booking for a different user.
     * @deny (update) User tries to update someone else's room booking.
     * @deny (delete) User tries to delete someone else's room booking.
     * @principle Enforces document ownership, restricts access to a user's own data.
     */
    match /users/{userId}/bookings/{bookingId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.renterId == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.renterId == resource.data.renterId;
      allow delete: if isExistingOwner(userId);
    }
  }
}