
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isJobEmployer(jobId) {
      return isAuthenticated() && get(/databases/$(database)/documents/jobs/$(jobId)).data.employerId == request.auth.uid;
    }

    function isRoomOwner(roomId) {
      return isAuthenticated() && get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid;
    }

    // USER PROFILES
    match /users/{userId} {
      allow read: if isOwner(userId) || (isAuthenticated() && resource.data.email == request.auth.token.email);
      allow write: if isOwner(userId);
      
      // USER SUBCOLLECTIONS (Bookings, Applications, Favorites)
      match /bookings/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /applications/{applicationId} {
        allow read, create, delete: if isOwner(userId);
        // The employer who owns the job can update the application status or delete it.
        allow update, delete: if isAuthenticated() && get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId == request.auth.uid;
      }

      match /favoriteJobs/{favoriteId} {
        allow read, write: if isOwner(userId);
      }

      match /favoriteRooms/{favoriteId} {
        allow read, write: if isOwner(userId);
      }

      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        
        // Allowed for the owner, or for seekers creating a "job_application" notification for an employer.
        allow create: if isOwner(userId) || (
          isAuthenticated() && 
          request.resource.data.type == 'job_application' &&
          request.resource.data.jobId != null &&
          request.resource.data.applicantId != null
        );
      }
    }

    // JOB LISTINGS
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.employerId == request.auth.uid;
      allow update: if isOwner(resource.data.employerId) || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastApplicantAt'])
      );
      allow delete: if isOwner(resource.data.employerId);

      // JOB APPLICANTS (Nested subcollection)
      match /applicants {
        // The job owner can list all applicants.
        allow list: if isJobEmployer(jobId);
      }

      match /applicants/{applicantId} {
        // The job owner can read, update, and delete individual applicant docs.
        allow read, delete, update: if isJobEmployer(jobId);
        
        // A seeker can read their OWN application record to check the status.
        allow get: if isAuthenticated() && resource.data.seekerId == request.auth.uid;
        
        // An authenticated user (seeker) can create an application for a job.
        allow create: if isAuthenticated() && request.resource.data.seekerId == request.auth.uid;
        
        // A seeker can also delete their own application.
        allow delete: if isAuthenticated() && resource.data.seekerId == request.auth.uid;
      }
    }

    // ROOM LISTINGS
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.ownerId);

      // RATINGS SUBCOLLECTION
      match /ratings/{ratingId} {
        allow read: if true;
        // Only authenticated users can write their own interest marker/rating.
        allow write: if isAuthenticated() && ratingId == request.auth.uid;
      }
    }
  }
}
