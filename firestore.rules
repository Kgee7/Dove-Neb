
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // USER PROFILES
    // Users can read and write to their own profile.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // USER SUBCOLLECTIONS
    // A user can manage their own bookings and create their own applications.
    match /users/{userId}/bookings/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/applications/{applicationId} {
      // A user can read their own applications.
      allow read: if isOwner(userId);
      // An employer can update the status of an application for a job they posted.
      // This rule is more secure: it checks that only the status can be changed,
      // and verifies the request is coming from the actual job owner.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                    && isOwner(get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId);
      // Only the user can create or delete their own application records.
      allow create, delete: if isOwner(userId);
    }

    // PUBLIC JOB LISTINGS
    // Anyone can read job listings.
    // Only authenticated employers can create jobs.
    // Only the employer who created the job can update or delete it.
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.employerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.employerId);
    }
    
    // JOB APPLICANTS SUBCOLLECTION
    // An authenticated user (seeker) can create an application for a job.
    // The employer who owns the job can read, update, and delete applications for their jobs.
    match /jobs/{jobId}/applicants/{applicantId} {
        allow create: if request.auth != null && request.resource.data.seekerId == request.auth.uid;
        allow read, update, delete: if isOwner(get(/databases/$(database)/documents/jobs/$(jobId)).data.employerId);
    }

    // PUBLIC ROOM LISTINGS
    // Anyone can read room listings.
    // Only authenticated users can create rooms.
    // Only the user who created the room can update or delete it.
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.ownerId);
    }
  }
}
